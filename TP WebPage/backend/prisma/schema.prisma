// Trainee Portal — production schema.
// Translates backend/docs/DATABASE_DESIGN.md into a working Prisma schema.
// DB table/column names stay snake_case (via @@map/@map) matching the design doc's raw SQL;
// Prisma client field/model names are idiomatic camelCase/PascalCase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries: point this at a pooled connection string (e.g. Neon's "-pooler" host,
  // or PgBouncer) in production so short-lived serverless/PaaS instances don't exhaust
  // Postgres' connection limit.
  url       = env("DATABASE_URL")
  // Schema migrations need a direct (non-pooled) connection. Set DIRECT_URL to the same
  // value as DATABASE_URL if you're not using a pooler (e.g. local dev).
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum BatchProgram {
  BA
  DataEngineering @map("Data Engineering")
  AIML            @map("AI ML")
  UIUX            @map("UI/UX")
}

enum BatchTrack {
  BTech
  MBA
}

enum BatchStatus {
  Active
  Upcoming
}

enum AssignmentStatus {
  Draft
  Open
  Closed
}

enum SubmissionStatus {
  NotStarted  @map("Not Started")
  UnderReview @map("Under Review")
  Completed
  Late
}

enum FacilitatorRole {
  PrimaryCoordinator @map("Primary Coordinator")
  LeadFacilitator    @map("Lead Facilitator")
  Trainer
  GuestTrainer       @map("Guest Trainer")
  AssignmentReviewer @map("Assignment Reviewer")
  BackupFacilitator  @map("Backup Facilitator")
}

enum FacilitatorAssignmentStatus {
  Active
  Upcoming
  TemporarilyUnavailable @map("Temporarily Unavailable")
  Completed
  Removed
}

enum SessionPlatform {
  GoogleMeet     @map("Google Meet")
  MicrosoftTeams @map("Microsoft Teams")
  Zoom
  Other
}

enum SessionStatus {
  Upcoming
  Live
  Completed
  Cancelled
  Rescheduled
}

enum AttendanceStatus {
  Present
  Absent
  Late
  Excused
}

enum AnnouncementPriority {
  Normal
  Important
  Critical
}

enum DiscussionRole {
  admin
  facilitator
  trainee
}

enum InviteStatus {
  Pending
  Accepted
  Expired
  Revoked
}

enum FeedbackDirection {
  FacilitatorToTrainee
  TraineeToFacilitator
}

enum SessionFeedbackAudience {
  Trainees
  Facilitators
  Both
}

// Batch/program-level feedback forms (Mid-Program, Final Program, etc.) support a wider audience
// than session/assignment forms -- they can reasonably target Primary Coordinators or Admins too,
// not just Trainees/Facilitators/Both. Kept as its own enum rather than widening
// SessionFeedbackAudience so the already-shipped session/assignment features are undisturbed.
enum FeedbackFormBroadAudience {
  Trainees
  Facilitators
  PrimaryCoordinators
  Admins
  MultipleRoles
}

enum BatchFeedbackFormType {
  BatchFeedback
  MidProgramFeedback
  FinalProgramFeedback
  CustomFeedback
}

enum FeedbackFormStatus {
  Draft
  Scheduled
  Active
  Closed
  Archived
  InvalidLink
}

// ---------- Auth & identity ----------

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  invites     UserInvite[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String    @map("password_hash")
  roleId              Int       @map("role_id")
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  role Role @relation(fields: [roleId], references: [id])

  profile                         UserProfile?
  refreshTokens                   RefreshToken[]
  passwordResetTokens             PasswordResetToken[]
  invitesSent                     UserInvite[]                   @relation("InviteSentBy")
  batchesAsFacilitator            Batch[]                        @relation("BatchFacilitator")
  batchEnrollments                BatchTrainee[]
  assignmentsCreated              Assignment[]
  submissions                     Submission[]
  sessionsAsFacilitator           Session[]
  attendanceMarked                Attendance[]                   @relation("AttendanceMarkedBy")
  attendanceRecords               Attendance[]                   @relation("AttendanceTrainee")
  resourcesUploaded               Resource[]
  feedbackAsTrainee               FeedbackEntry[]                @relation("FeedbackTrainee")
  feedbackAsFacilitator           FeedbackEntry[]                @relation("FeedbackFacilitator")
  sessionFeedbackFormsCreated     SessionFeedbackForm[]
  sessionFeedbackSubmissions      SessionFeedbackSubmission[]
  assignmentFeedbackFormsCreated  AssignmentFeedbackForm[]
  assignmentFeedbackSubmissions   AssignmentFeedbackSubmission[]
  batchFeedbackFormsCreated       BatchFeedbackForm[]
  batchFeedbackSubmissions        BatchFeedbackSubmission[]
  announcements                   Announcement[]
  announcementReads               AnnouncementRead[]
  discussionThreads               DiscussionThread[]
  discussionMessages              DiscussionMessage[]
  auditLogEntries                 AuditLog[]
  notificationReads               NotificationRead[]
  notifications                   Notification[]
  batchFacilitatorAssignments     BatchFacilitator[]             @relation("BatchFacilitatorAssignments")
  batchFacilitatorAssignmentsMade BatchFacilitator[]             @relation("BatchFacilitatorAssignedBy")

  // Matches the admin user-listing endpoint's role filter (GET /users?role=...).
  @@index([roleId])
  @@map("users")
}

model UserProfile {
  userId           String    @id @map("user_id")
  phone            String?
  location         String?
  company          String?
  department       String?
  idNumber         String?   @map("id_number")
  avatarStorageKey String?   @map("avatar_storage_key")
  avatarMimeType   String?   @map("avatar_mime_type")
  avatarSizeBytes  Int?      @map("avatar_size_bytes")
  avatarUpdatedAt  DateTime? @map("avatar_updated_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserInvite {
  id         String       @id @default(uuid())
  email      String
  roleId     Int          @map("role_id")
  invitedBy  String?      @map("invited_by")
  tokenHash  String       @unique @map("token_hash")
  status     InviteStatus @default(Pending)
  expiresAt  DateTime     @map("expires_at")
  acceptedAt DateTime?    @map("accepted_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  role    Role  @relation(fields: [roleId], references: [id])
  inviter User? @relation("InviteSentBy", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@index([email, status])
  @@map("user_invites")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  rememberMe Boolean   @default(false) @map("remember_me")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Single-use, short-lived token backing the emailed password-reset flow
// (auth.service.ts requestPasswordReset/resetPassword). Only the SHA-256
// hash is stored, same as invites — a DB leak alone can't reset passwords.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------- Training plans ----------
// A TrainingPlan is the org's fixed curriculum template (only "BA BTech" and "BA MBA" exist).
// Creating a Batch against a plan instantiates copies of its sessions/assignments/resources/
// announcements onto that batch (see batches.service.ts `create()`); edits to those per-batch
// copies never mutate the template, they only keep a nullable FK back to it for traceability.

model TrainingPlan {
  id                              String   @id @default(uuid())
  code                            String   @unique
  name                            String
  description                     String   @default("")
  durationMonths                  Int      @default(2) @map("duration_months")
  // Reusable schedule defaults (minutes from midnight) — batch automation and the Admin editing
  // UI both read these instead of each hardcoding the org's standard timings separately.
  // Session: 14:30-16:30. Assignment: opens in the morning, due end-of-day (23:59).
  defaultSessionStartMinute       Int      @default(870) @map("default_session_start_minute")
  defaultSessionEndMinute         Int      @default(990) @map("default_session_end_minute")
  defaultAssignmentStartMinute    Int      @default(570) @map("default_assignment_start_minute")
  defaultAssignmentDeadlineMinute Int      @default(1439) @map("default_assignment_deadline_minute")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  sessions      TrainingPlanSession[]
  assignments   TrainingPlanAssignment[]
  resources     TrainingPlanResource[]
  announcements TrainingPlanAnnouncement[]
  batches       Batch[]

  @@map("training_plans")
}

model TrainingPlanSession {
  id              String          @id @default(uuid())
  trainingPlanId  String          @map("training_plan_id")
  title           String
  // What the session is meant to cover — shown alongside the title in the schedule/calendar.
  agenda          String          @default("")
  // Day N of the plan's duration — combined with a batch's startMonth to compute the actual
  // scheduledAt of the Session instantiated from this template row.
  dayOffset       Int             @map("day_offset")
  startMinute     Int             @map("start_minute")
  endMinute       Int             @map("end_minute")
  platform        SessionPlatform @default(Other)
  order           Int
  // Default feedback-form link copied onto instantiated Sessions; editable per-batch afterward.
  feedbackFormUrl String?         @map("feedback_form_url")

  trainingPlan TrainingPlan             @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  assignments  TrainingPlanAssignment[]
  sessions     Session[]

  @@index([trainingPlanId])
  @@map("training_plan_sessions")
}

model TrainingPlanAssignment {
  id               String  @id @default(uuid())
  trainingPlanId   String  @map("training_plan_id")
  title            String
  // What the assignment is meant to achieve (e.g. "Requirement Gathering", "SQL Basics") —
  // shown in Assignment Details alongside the free-text description.
  agenda           String  @default("")
  description      String  @default("")
  dueDayOffset     Int     @map("due_day_offset")
  relatedSessionId String? @map("related_session_id")

  trainingPlan   TrainingPlan         @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  relatedSession TrainingPlanSession? @relation(fields: [relatedSessionId], references: [id], onDelete: SetNull)
  assignments    Assignment[]

  @@index([trainingPlanId])
  @@map("training_plan_assignments")
}

model TrainingPlanResource {
  id             String @id @default(uuid())
  trainingPlanId String @map("training_plan_id")
  title          String
  category       String
  url            String

  trainingPlan TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  resources    Resource[]

  @@index([trainingPlanId])
  @@map("training_plan_resources")
}

model TrainingPlanAnnouncement {
  id             String               @id @default(uuid())
  trainingPlanId String               @map("training_plan_id")
  title          String
  message        String
  priority       AnnouncementPriority @default(Normal)

  trainingPlan  TrainingPlan   @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  announcements Announcement[]

  @@index([trainingPlanId])
  @@map("training_plan_announcements")
}

// ---------- Batches ----------

model Batch {
  id             String       @id @default(uuid())
  code           String       @unique
  name           String
  program        BatchProgram
  track          BatchTrack
  trainingPlanId String       @map("training_plan_id")
  facilitatorId  String?      @map("facilitator_id")
  startMonth     DateTime?    @map("start_month")
  endDate        DateTime?    @map("end_date")
  status         BatchStatus  @default(Upcoming)
  archivedAt     DateTime?    @map("archived_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  trainingPlan TrainingPlan @relation(fields: [trainingPlanId], references: [id])
  facilitator  User?        @relation("BatchFacilitator", fields: [facilitatorId], references: [id], onDelete: SetNull)

  trainees               BatchTrainee[]
  assignments            Assignment[]
  assignmentBatches      AssignmentBatch[]
  sessions               Session[]
  resources              Resource[]
  feedback               FeedbackEntry[]
  discussions            DiscussionThread[]
  announcements          Announcement[]
  notifications          Notification[]
  facilitatorAssignments BatchFacilitator[]
  feedbackForms          BatchFeedbackForm[]

  @@index([facilitatorId])
  @@index([status])
  @@index([trainingPlanId])
  @@map("batches")
}

// A batch's facilitator team is many-to-many (one batch, many facilitators; one facilitator,
// many batches), with exactly one assignment marked isPrimaryCoordinator per batch at a time --
// enforced in services/facilitatorAssignments.service.ts's setPrimary/remove, not by a DB
// constraint. Batch.facilitatorId (above) stays as a denormalized cache of whichever assignment
// currently holds isPrimaryCoordinator, kept in sync by that same service, so every existing
// single-facilitator check elsewhere in the backend keeps working unchanged for coordinator-level
// access. A surrogate id (not a composite [batchId, facilitatorId] PK) is used deliberately: a
// removed-then-rejoined facilitator gets a fresh row rather than reusing history, matching the
// duplicate check in create() which only excludes status: Removed rows.
model BatchFacilitator {
  id                   String                      @id @default(uuid())
  batchId              String                      @map("batch_id")
  facilitatorId        String                      @map("facilitator_id")
  role                 FacilitatorRole
  isPrimaryCoordinator Boolean                     @default(false) @map("is_primary_coordinator")
  status               FacilitatorAssignmentStatus @default(Active)
  assignedAt           DateTime                    @default(now()) @map("assigned_at")
  assignedBy           String?                     @map("assigned_by")
  notes                String?

  batch          Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  facilitator    User  @relation("BatchFacilitatorAssignments", fields: [facilitatorId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("BatchFacilitatorAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([facilitatorId])
  @@map("batch_facilitators")
}

model BatchTrainee {
  batchId    String    @map("batch_id")
  traineeId  String    @map("trainee_id")
  enrolledAt DateTime  @default(now()) @map("enrolled_at")
  removedAt  DateTime? @map("removed_at")

  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  trainee User  @relation(fields: [traineeId], references: [id], onDelete: Cascade)

  @@id([batchId, traineeId])
  @@index([traineeId])
  @@map("batch_trainees")
}

// ---------- Assignments & submissions ----------

model Assignment {
  id                         String           @id @default(uuid())
  // Primary/first batch — kept for backward compatibility with existing single-batch reads.
  // The authoritative set of assigned batches is the AssignmentBatch join table below.
  batchId                    String           @map("batch_id")
  // Nullable: assignments belong to a Training Plan/batch, not necessarily an individual
  // facilitator — this is only set when a specific trainer owns/created the assignment.
  facilitatorId              String?          @map("facilitator_id")
  // Template this assignment was instantiated from (null for manually-created ad-hoc assignments).
  trainingPlanAssignmentId   String?          @map("training_plan_assignment_id")
  // The session this assignment is tied to — drives "Related Session" on the assignment and
  // "Related Assignment" on the session (via the reverse relation), a single FK for both views.
  sessionId                  String?          @map("session_id")
  title                      String
  // What the assignment is meant to achieve (e.g. "Requirement Gathering", "SQL Basics").
  agenda                     String           @default("")
  description                String           @default("")
  status                     AssignmentStatus @default(Draft)
  deadline                   DateTime
  attachmentOriginalFilename String?          @map("attachment_original_filename")
  attachmentStorageKey       String?          @unique @map("attachment_storage_key")
  attachmentMimeType         String?          @map("attachment_mime_type")
  attachmentSizeBytes        Int?             @map("attachment_size_bytes")
  createdAt                  DateTime         @default(now()) @map("created_at")
  updatedAt                  DateTime         @updatedAt @map("updated_at")
  deletedAt                  DateTime?        @map("deleted_at")

  batch                  Batch                   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  facilitator            User?                   @relation(fields: [facilitatorId], references: [id])
  trainingPlanAssignment TrainingPlanAssignment? @relation(fields: [trainingPlanAssignmentId], references: [id], onDelete: SetNull)
  session                Session?                @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  submissions            Submission[]
  batches                AssignmentBatch[]
  feedbackForm           AssignmentFeedbackForm?

  @@index([batchId])
  @@index([deadline])
  @@index([sessionId])
  @@map("assignments")
}

// Many-to-many Assignment↔Batch. Every assignment has at least one row here (including its
// `batchId` primary batch), added at create time; additional rows represent extra batches the
// same assignment was also assigned to.
model AssignmentBatch {
  assignmentId String   @map("assignment_id")
  batchId      String   @map("batch_id")
  createdAt    DateTime @default(now()) @map("created_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  batch      Batch      @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@id([assignmentId, batchId])
  @@index([batchId])
  @@map("assignment_batches")
}

model Submission {
  id           String           @id @default(uuid())
  assignmentId String           @map("assignment_id")
  traineeId    String           @map("trainee_id")
  status       SubmissionStatus @default(NotStarted)
  submittedAt  DateTime?        @map("submitted_at")
  grade        Decimal?         @db.Decimal(5, 2)
  feedback     String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  assignment  Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  trainee     User                   @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  attachments SubmissionAttachment[]

  @@unique([assignmentId, traineeId])
  @@index([traineeId])
  @@index([status])
  @@map("submissions")
}

model SubmissionAttachment {
  id               String   @id @default(uuid())
  submissionId     String   @map("submission_id")
  originalFilename String   @map("original_filename")
  storageKey       String   @unique @map("storage_key")
  mimeType         String   @map("mime_type")
  sizeBytes        Int      @map("size_bytes")
  // False once a newer attachment supersedes this one on resubmission — kept (not deleted) to
  // preserve submission history; only the current row is served by the default download route.
  isCurrent        Boolean  @default(true) @map("is_current")
  uploadedAt       DateTime @default(now()) @map("uploaded_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([submissionId, isCurrent])
  @@map("submission_attachments")
}

// ---------- Sessions & attendance ----------

model Session {
  id                    String          @id @default(uuid())
  batchId               String          @map("batch_id")
  // Nullable: the "Trainer" for a session is optional (per the org's Training Plan workflow) —
  // most sessions are generated from a template with no specific trainer pre-assigned.
  facilitatorId         String?         @map("facilitator_id")
  // Template this session was instantiated from (null for manually-scheduled ad-hoc sessions).
  trainingPlanSessionId String?         @map("training_plan_session_id")
  title                 String
  agenda                String          @default("")
  scheduledAt           DateTime        @map("scheduled_at")
  // How long the session runs from scheduledAt (e.g. 120 for the org's standard 2:30-4:30 PM
  // instructor-led block) — without this the UI has no way to know a session's end time.
  durationMinutes       Int             @default(120) @map("duration_minutes")
  platform              SessionPlatform @default(Other)
  meetingLink           String?         @map("meeting_link")
  status                SessionStatus   @default(Upcoming)
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  deletedAt             DateTime?       @map("deleted_at")

  batch               Batch                @relation(fields: [batchId], references: [id], onDelete: Cascade)
  facilitator         User?                @relation(fields: [facilitatorId], references: [id])
  trainingPlanSession TrainingPlanSession? @relation(fields: [trainingPlanSessionId], references: [id], onDelete: SetNull)
  attendance          Attendance[]
  relatedAssignments  Assignment[]
  feedbackForm        SessionFeedbackForm?

  @@index([batchId])
  @@index([scheduledAt])
  @@map("sessions")
}

model Attendance {
  id        String           @id @default(uuid())
  sessionId String           @map("session_id")
  traineeId String           @map("trainee_id")
  status    AttendanceStatus
  markedBy  String?          @map("marked_by")
  markedAt  DateTime         @default(now()) @map("marked_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  trainee User    @relation("AttendanceTrainee", fields: [traineeId], references: [id], onDelete: Cascade)
  marker  User?   @relation("AttendanceMarkedBy", fields: [markedBy], references: [id], onDelete: SetNull)

  @@unique([sessionId, traineeId])
  @@index([traineeId])
  @@map("attendance")
}

// ---------- Resources ----------

model Resource {
  id                     String    @id @default(uuid())
  batchId                String?   @map("batch_id")
  // Template this resource was instantiated from (null for manually-uploaded resources).
  trainingPlanResourceId String?   @map("training_plan_resource_id")
  title                  String
  category               String
  version                String    @default("v1.0")
  // Exactly one of storageKey (uploaded file) or externalUrl (shared link — e.g. resources
  // copied from a Training Plan template) is set; enforced at the application layer, not the DB.
  storageKey             String?   @unique @map("storage_key")
  mimeType               String?   @map("mime_type")
  sizeBytes              BigInt?   @map("size_bytes")
  externalUrl            String?   @map("external_url")
  downloadCount          Int       @default(0) @map("download_count")
  verified               Boolean   @default(false)
  uploadedBy             String    @map("uploaded_by")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  batch                Batch?                @relation(fields: [batchId], references: [id], onDelete: Cascade)
  uploader             User                  @relation(fields: [uploadedBy], references: [id])
  trainingPlanResource TrainingPlanResource? @relation(fields: [trainingPlanResourceId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([category])
  @@map("resources")
}

// ---------- Feedback ----------

// Session Feedback: an external form link (Google/Microsoft Forms) attached to a Session, plus
// per-trainee submission tracking for stats and the trainee's Pending/Completed status. Distinct
// from FeedbackEntry (facilitator<->trainee performance ratings) below, which is unrelated.
model SessionFeedbackForm {
  id          String                  @id @default(uuid())
  sessionId   String                  @unique @map("session_id")
  name        String
  description String                  @default("")
  formUrl     String                  @map("form_url")
  // Who the form is meant for — narrows which role(s) see it attached to their session view.
  audience    SessionFeedbackAudience @default(Both)
  createdBy   String                  @map("created_by")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  session     Session                     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  creator     User                        @relation(fields: [createdBy], references: [id])
  submissions SessionFeedbackSubmission[]

  @@map("session_feedback_forms")
}

model SessionFeedbackSubmission {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  // The trainee OR facilitator who submitted — a form's audience can target either (or both), so
  // this isn't trainee-only despite the model's name being "session feedback".
  submitterId String   @map("submitter_id")
  submittedAt DateTime @default(now()) @map("submitted_at")

  form      SessionFeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  submitter User                @relation(fields: [submitterId], references: [id], onDelete: Cascade)

  @@unique([formId, submitterId])
  @@index([submitterId])
  @@map("session_feedback_submissions")
}

// Assignment Feedback: the same external-form-link pattern as SessionFeedbackForm above, but
// attached directly to an Assignment — for feedback that belongs to a piece of work rather than
// a session (an assignment with no related session, or work-specific surveys). Shares the
// SessionFeedbackAudience enum so both features gate visibility identically.
model AssignmentFeedbackForm {
  id           String                  @id @default(uuid())
  assignmentId String                  @unique @map("assignment_id")
  name         String
  description  String                  @default("")
  formUrl      String                  @map("form_url")
  audience     SessionFeedbackAudience @default(Both)
  createdBy    String                  @map("created_by")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  assignment  Assignment                     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  creator     User                           @relation(fields: [createdBy], references: [id])
  submissions AssignmentFeedbackSubmission[]

  @@map("assignment_feedback_forms")
}

model AssignmentFeedbackSubmission {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  // The trainee OR facilitator who submitted — same audience semantics as session feedback.
  submitterId String   @map("submitter_id")
  submittedAt DateTime @default(now()) @map("submitted_at")

  form      AssignmentFeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  submitter User                   @relation(fields: [submitterId], references: [id], onDelete: Cascade)

  @@unique([formId, submitterId])
  @@index([submitterId])
  @@map("assignment_feedback_submissions")
}

// Feedback attached to a whole batch/program rather than one session or assignment -- Mid-Program
// Feedback, Final Program Feedback, Batch Experience Feedback, etc. Unlike SessionFeedbackForm/
// AssignmentFeedbackForm (one form per session/assignment, enforced via a @unique parent id), a
// batch can have several of these at once, so batchId is a plain indexed FK, not @unique.
model BatchFeedbackForm {
  id           String                    @id @default(uuid())
  batchId      String                    @map("batch_id")
  name         String
  description  String                    @default("")
  formUrl      String                    @map("form_url")
  formType     BatchFeedbackFormType     @default(BatchFeedback) @map("form_type")
  audience     FeedbackFormBroadAudience @default(Trainees)
  status       FeedbackFormStatus        @default(Draft)
  isRequired   Boolean                   @default(false) @map("is_required")
  instructions String?
  openDate     DateTime?                 @map("open_date")
  dueDate      DateTime?                 @map("due_date")
  createdBy    String                    @map("created_by")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  batch       Batch                      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  creator     User                       @relation(fields: [createdBy], references: [id])
  submissions BatchFeedbackSubmission[]

  @@index([batchId])
  @@map("batch_feedback_forms")
}

model BatchFeedbackSubmission {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  submitterId String   @map("submitter_id")
  submittedAt DateTime @default(now()) @map("submitted_at")

  form      BatchFeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  submitter User              @relation(fields: [submitterId], references: [id], onDelete: Cascade)

  @@unique([formId, submitterId])
  @@index([submitterId])
  @@map("batch_feedback_submissions")
}

model FeedbackEntry {
  id            String            @id @default(uuid())
  batchId       String            @map("batch_id")
  traineeId     String            @map("trainee_id")
  facilitatorId String            @map("facilitator_id")
  // Who authored the feedback — kept default FacilitatorToTrainee so every existing row
  // (created before this field existed) is interpreted the same way it always behaved.
  direction     FeedbackDirection @default(FacilitatorToTrainee)
  category      String
  rating        Int
  comment       String?
  createdAt     DateTime          @default(now()) @map("created_at")

  batch       Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  trainee     User  @relation("FeedbackTrainee", fields: [traineeId], references: [id], onDelete: Cascade)
  facilitator User  @relation("FeedbackFacilitator", fields: [facilitatorId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([traineeId])
  @@index([facilitatorId])
  @@index([direction])
  @@map("feedback_entries")
}

// ---------- Announcements & discussions ----------

model Announcement {
  id                         String               @id @default(uuid())
  authorId                   String               @map("author_id")
  // Batch this announcement is scoped to (null = global). Populated automatically when a batch
  // is created from a Training Plan's default announcements.
  batchId                    String?              @map("batch_id")
  trainingPlanAnnouncementId String?              @map("training_plan_announcement_id")
  title                      String
  message                    String
  priority                   AnnouncementPriority @default(Normal)
  audience                   String
  pinned                     Boolean              @default(false)
  scheduledFor               DateTime?            @map("scheduled_for")
  expiresAt                  DateTime?            @map("expires_at")
  createdAt                  DateTime             @default(now()) @map("created_at")
  updatedAt                  DateTime             @updatedAt @map("updated_at")
  deletedAt                  DateTime?            @map("deleted_at")

  author                   User                      @relation(fields: [authorId], references: [id])
  batch                    Batch?                    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  trainingPlanAnnouncement TrainingPlanAnnouncement? @relation(fields: [trainingPlanAnnouncementId], references: [id], onDelete: SetNull)
  reads                    AnnouncementRead[]

  @@index([pinned])
  @@index([batchId])
  @@map("announcements")
}

model AnnouncementRead {
  announcementId String   @map("announcement_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@map("announcement_reads")
}

model DiscussionThread {
  id        String    @id @default(uuid())
  batchId   String    @map("batch_id")
  authorId  String    @map("author_id")
  title     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  batch    Batch               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  author   User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  messages DiscussionMessage[]

  @@index([batchId])
  @@map("discussion_threads")
}

model DiscussionMessage {
  id                 String         @id @default(uuid())
  threadId           String         @map("thread_id")
  authorId           String         @map("author_id")
  authorRoleSnapshot DiscussionRole @map("author_role_snapshot")
  body               String
  createdAt          DateTime       @default(now()) @map("created_at")
  deletedAt          DateTime?      @map("deleted_at")

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("discussion_messages")
}

// ---------- Audit log & notifications ----------

model AuditLog {
  id            String   @id @default(uuid())
  occurredAt    DateTime @default(now()) @map("occurred_at")
  eventType     String   @map("event_type")
  message       String
  actorId       String?  @map("actor_id")
  module        String
  previousValue String?  @map("previous_value")
  newValue      String?  @map("new_value")
  ipAddress     String?  @map("ip_address")

  actor User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)
  reads NotificationRead[]

  @@index([occurredAt(sort: Desc)])
  @@index([actorId])
  @@index([module])
  @@map("audit_log")
}

model NotificationRead {
  auditLogId String   @map("audit_log_id")
  userId     String   @map("user_id")
  readAt     DateTime @default(now()) @map("read_at")

  auditLog AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([auditLogId, userId])
  @@map("notification_reads")
}

enum NotificationSeverity {
  Info
  Warning
  Critical
}

// A real, per-recipient notification -- distinct from AuditLog (which is a compliance/audit
// trail, not a delivery mechanism, and has no recipient concept). One row per recipient, decided
// at generation time (see services/notifications.service.ts's notifyUser/notifyUsers/notifyRole/
// notifyBatch helpers) rather than one shared "event" row with scope resolved at read time -- so
// every read/write in this table is a trivial `where: { recipientId: <caller> }`, with no
// dynamic scope-resolution path that could leak another user's notifications.
model Notification {
  id          String               @id @default(uuid())
  recipientId String               @map("recipient_id")
  type        String
  title       String
  message     String
  targetUrl   String?              @map("target_url")
  severity    NotificationSeverity @default(Info)
  // Context only (e.g. for a "View this batch" link or future filtering) -- never used to
  // authorize access; authorization is always solely by recipientId.
  batchId     String?              @map("batch_id")
  createdAt   DateTime             @default(now()) @map("created_at")
  readAt      DateTime?            @map("read_at")

  recipient User   @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  batch     Batch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([recipientId, readAt])
  @@map("notifications")
}
