# Server
NODE_ENV=development
PORT=4000

# PostgreSQL connection string (see README "Database setup").
# In production, point this at a POOLED connection (e.g. Neon's "-pooler" host, or PgBouncer) —
# short-lived PaaS instances can otherwise exhaust Postgres' direct connection limit.
DATABASE_URL="postgresql://user:password@localhost:5432/trainee_portal?schema=public"

# Prisma Migrate needs a DIRECT (non-pooled) connection. If you're not using a pooler
# (e.g. local dev), set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/trainee_portal?schema=public"

# JWT — use long, random values in every real environment (e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-16-chars
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_TOKEN_REMEMBER_TTL_DAYS=30

# Signs the httpOnly refresh-token cookie
COOKIE_SECRET=replace-with-a-random-secret-at-least-16-chars

# bcrypt work factor
BCRYPT_SALT_ROUNDS=12

# Account lockout after repeated failed logins (defense-in-depth alongside IP rate limiting)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Comma-separated list of allowed frontend origins (the deployed Vercel URL(s) in production —
# this is what the task brief calls CLIENT_URL; the code's actual variable name is CORS_ORIGIN)
CORS_ORIGIN=http://localhost:5173

# File uploads (assignment attachments, resources, avatars).
# UPLOAD_DIR/MAX_UPLOAD_SIZE_MB apply regardless of provider. STORAGE_PROVIDER=local writes to
# UPLOAD_DIR on local disk — fine for dev, but that disk does NOT persist across deploys/restarts
# on Railway or Render. Use STORAGE_PROVIDER=s3 in production (see backend/README.md).
UPLOAD_DIR=src/uploads
MAX_UPLOAD_SIZE_MB=10
STORAGE_PROVIDER=local

# Required only when STORAGE_PROVIDER=s3
AWS_REGION=
AWS_S3_BUCKET=
# Optional: omit both to use the default AWS credential chain (IAM role, etc.) instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Not implemented — no email service is wired up (POST /api/auth/invite returns the raw token
# instead of emailing it; see backend/README.md "Known limitations"). Set these if you add one.
EMAIL_FROM=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# Optional error tracking. Unset = disabled, no SDK installed (see src/utils/monitoring.ts for
# the integration point and DEPLOYMENT.md's monitoring checklist).
SENTRY_DSN=
