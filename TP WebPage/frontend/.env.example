# Base URL for the backend API. In dev this is proxied by Vite (see vite.config.ts),
# so the default of /api works unchanged. Point this at your deployed backend origin in
# production, e.g. https://trainee-portal-backend.up.railway.app/api
VITE_API_URL=/api

# Not implemented — this codebase has no WebSocket/Socket.io client or server (verified: no
# socket.io/ws code anywhere in frontend/backend). Left here as a placeholder in case real-time
# features are added later; unused until then.
VITE_SOCKET_URL=

# Optional error tracking. Unset = disabled, no SDK installed (see src/utils/monitoring.ts for
# the integration point and DEPLOYMENT.md's monitoring checklist).
VITE_SENTRY_DSN=
